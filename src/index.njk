---
layout: layout.njk
title: Solutions
---

<div>
  <div style="margin-top: 2rem; display: flex; gap: 2rem;">
    <div>
      <span style="font-size: 2rem; font-weight: bold; color: var(--accent-color);">{{ collections.problems.length }}</span>
      <p style="margin: 0; color: #8b949e;">Problems Solved</p>
    </div>
  </div>

  <div class="mobile-problems">
    <hr style="margin: 2rem 0; border: none; border-top: 1px solid var(--border-color);">
    <h3>All Problems</h3>
    <ul style="list-style: none; padding: 0;">
      {% for problem in collections.problems | sort(false, false, 'data.title') %}
      <li style="margin-bottom: 0.5rem;">
        <a href="{{ problem.url | url }}">{{ problem.data.title }}</a>
      </li>
      {% endfor %}
    </ul>
  </div>
</div>

---
layout: layout.njk
title: Solutions
---

<h1>Problem Solutions</h1>

<div class="problems-list">
  {% for problem in collections.problems %}
    <div class="problem-card">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
        <h2 style="margin: 0; font-size: 1.25rem;">
          <a href="{{ problem.url | url }}" style="color: var(--accent-color);">{{ problem.data.title }}</a>
        </h2>
      </div>
      <div style="font-size: 0.9rem; color: #8b949e;">
        {% for tag in problem.data.tags %}
          {% if tag != "problems" %}
            <span style="margin-right: 1rem;">#{{ tag }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% else %}
    <p>No problems found. Run the sync script to generate content!</p>
  {% endfor %}
</div>
